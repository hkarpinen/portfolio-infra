# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=changeme

# JWT — must be at least 32 characters
JWT_SECRET=changeme-at-least-32-chars-long!

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Connection strings
IDENTITY_CONN=Host=postgres;Database=identity_db;Username=postgres;Password=changeme
FORUM_CONN=Host=postgres;Database=forum_db;Username=postgres;Password=changeme
BILLS_CONN=Host=postgres;Database=bills_db;Username=postgres;Password=changeme
