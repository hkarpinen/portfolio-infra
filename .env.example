# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=changeme

# JWT — must be at least 32 characters
JWT_SECRET=changeme-at-least-32-chars-long!

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Connection strings
IDENTITY_CONN=Host=postgres;Database=identity_db;Username=postgres;Password=changeme
FORUM_CONN=Host=postgres;Database=forum_db;Username=postgres;Password=changeme
FINANCE_CONN=Host=postgres;Database=finance_db;Username=postgres;Password=changeme

# Plaid — https://dashboard.plaid.com/team/keys
# Sign up, copy Client ID + Sandbox secret, then create an ngrok/cloudflared
# tunnel to your finance service and paste the public URL as the webhook URL.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=sandbox
PLAID_WEBHOOK_URL=https://your-tunnel.ngrok.io/api/finance/plaid/webhook
